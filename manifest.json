{
  "name": "transcribe",
  "description": "Transcribes an audio file to text using Whisper.",
  "version": "0.1.0",
  "type": "command",
  "command": "whisper {{file_path}} --model ${TORII_WHISPER_MODEL:-base} --output_format txt --output_dir /tmp && cat /tmp/$(basename {{file_path}} .ogg).txt && rm -f /tmp/$(basename {{file_path}} .ogg).txt",
  "parameters": {
    "type": "object",
    "properties": {
      "file_path": { "type": "string", "description": "Path to the audio file to transcribe" }
    },
    "required": ["file_path"]
  },
  "env": ["TORII_WHISPER_MODEL"]
}
